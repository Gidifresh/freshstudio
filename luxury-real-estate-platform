<div class="p-8 bg-slate-900 min-h-screen text-white flex flex-col items-center justify-center">
  <h1 class="text-4xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-emerald-400 mb-4">
    Tailwind Cloud IDE
  </h1>
  <p class="text-lg text-slate-300 max-w-md text-center mb-8">
    Write HTML with Tailwind CSS classes on the left and see your changes instantly on the right.
  </p>
  <button class="px-6 py-3 bg-blue-600 hover:bg-blue-500 rounded-lg font-medium transition-colors shadow-lg shadow-blue-500/30">
    Get Started
  </button>
</div>
<section id="contact" class="py-16 bg-slate-50 text-gray-900">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-10">
      Contact Us
    </h2>

    <div class="grid md:grid-cols-2 gap-10">
      <!-- Contact Form -->
      <form action="https://formspree.io/f/mnjgaydr" method="POST" class="bg-white p-6 rounded-lg shadow-md">
        <input type="hidden" name="_subject" value="New Message From Website" />

        <label class="block mb-2 font-semibold">Name</label>
        <input type="text" name="name" required class="w-full mb-4 p-3 border rounded-lg" />

        <label class="block mb-2 font-semibold">Email</label>
        <input type="email" name="email" required class="w-full mb-4 p-3 border rounded-lg" />

        <label class="block mb-2 font-semibold">Phone</label>
        <input type="tel" name="phone" class="w-full mb-4 p-3 border rounded-lg" />

        <label class="block mb-2 font-semibold">Message</label>
        <textarea name="message" rows="4" required class="w-full mb-6 p-3 border rounded-lg"></textarea>

        <button type="submit" class="w-full bg-indigo-600 text-white py-3 rounded-lg font-bold hover:bg-indigo-700">
          Send Message
        </button>
      </form>

      <!-- Google Map -->
      <div class="w-full h-[400px] rounded-lg overflow-hidden shadow-md">
        <iframe
          src="https://maps.google.com/maps?q=Lekki%20Lagos&t=&z=13&ie=UTF8&iwloc=&output=embed"
          width="100%"
          height="100%"
          style="border:0;"
          loading="lazy"
          title="Google Map"
        ></iframe>
      </div>
    </div>
  </div>
</section>
