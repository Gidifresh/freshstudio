<!-- Contact Section with Formspree -->
<section id="contact" class="contact-section py-12 bg-white">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl font-bold mb-6 text-center text-gray-800">Contact Us</h2>
    
    <div class="flex flex-col md:flex-row gap-8">
      <!-- Form -->
      <form 
        action="https://formspree.io/f/mnjgaydr" 
        method="POST" 
        class="flex-1 bg-gray-50 p-6 rounded shadow"
      >
        <label class="block mb-2 font-semibold text-gray-800">Name</label>
        <input type="text" name="name" required class="w-full mb-4 p-2 border rounded" />

        <label class="block mb-2 font-semibold text-gray-800">Email</label>
        <input type="email" name="email" required class="w-full mb-4 p-2 border rounded" />

        <label class="block mb-2 font-semibold text-gray-800">Phone</label>
        <input type="text" name="phone" required class="w-full mb-4 p-2 border rounded" />

        <label class="block mb-2 font-semibold text-gray-800">Message</label>
        <textarea name="message" required class="w-full mb-4 p-2 border rounded" rows="4"></textarea>

        <button type="submit" class="bg-[#0a2540] text-[#ffd700] px-6 py-3 rounded font-bold hover:bg-[#0f3a63]">
          Send Message
        </button>
      </form>

      <!-- Google Map -->
      <div class="flex-1">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3966.1234567890!2d3.4023456789!3d6.4567890123!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x103b8b7c123456%3A0xabcdef1234567890!2sLekki%2C%20Lagos!5e0!3m2!1sen!2sng!4v1678901234567!5m2!1sen!2sng"
          width="100%"
          height="400"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>
    </div>
  </div> 
</section> 

